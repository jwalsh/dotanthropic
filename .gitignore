# Deny everything by default
*
.*

# Allow core repository files
!Makefile
!README.org
!shell.nix
!.gitignore

# Allow specific directories and their contents
!scripts/
!scripts/**
!config/
!config/**
!docs/
!docs/**

# Always ignore these even if matched above
.git/
.direnv/
result
result-*
*.swp
*.swo
*~
.DS_Store
!CHANGELOG.org

TAGS
*TAGS